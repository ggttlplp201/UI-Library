{
  "name": "component-style-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/studio",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "oxlint",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "oxlint": "^1.73.0"
  }
}
